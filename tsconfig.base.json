{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "paths": {
      "@panqueue/core": ["./packages/core/index.ts"],
      "@panqueue/config": ["./packages/config/index.ts"],
      "@panqueue/client": ["./packages/client/index.ts"],
      "@panqueue/worker": ["./packages/worker/index.ts"]
    },

    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "esnext",
    "lib": ["esnext", "dom", "dom.iterable"],
    "types": [],

    "strict": true,
    "noUncheckedIndexedAccess": false,
    "skipLibCheck": true,

    "declaration": true,
    "isolatedDeclarations": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,

    "noEmit": true
  }
}
