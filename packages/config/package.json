{
  "name": "@panqueue/config",
  "version": "0.0.1",
  "description": "Type-safe shared configuration for panqueue clients and workers.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./dist/mod.js",
    "./package.json": "./package.json"
  },
  "types": "./dist/mod.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@panqueue/core": "workspace:*"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json --isolatedDeclarations false --declaration false"
  }
}
